{
  "name": "gymtracker-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run migrate && tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "start:with-migrate": "npm run build && node dist/migrate.js && node dist/server.js",
    "migrate": "node dist/migrate.js",
    "db:setup": "npm run migrate",
    "exercise-db:sync": "tsx src/scripts/syncExerciseDb.ts --download-images",
    "exercise-db:refresh": "tsx src/scripts/syncExerciseDb.ts --download-images --no-cache",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jose": "^6.1.2",
    "openai": "^6.25.0",
    "pg": "^8.18.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
